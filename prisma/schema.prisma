// PropComply AI + VerifyMe Global - Enterprise Database Schema
// Trust Infrastructure Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// IDENTITY DOMAIN
// ============================================

model IdentityProfile {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  email           String   @unique
  phone           String?
  dateOfBirth     String?
  nationality     String?
  trustLevel      Int      @default(0) // 0-5 Trust Ladder
  trustScore      Float    @default(0) // 0-100
  status          String   @default("pending") // pending, verified, suspended, rejected
  consentGiven    Boolean  @default(false)
  gdprCompliant   Boolean  @default(false)
  userId          String?  // Links profile to User account for tenant data isolation
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User?    @relation(fields: [userId], references: [id])
  credentials     IdentityCredential[]
  evidence        IdentityEvidence[]
  verifications   VerificationRecord[]
  complianceChecks ComplianceCheck[]
  riskScores      RiskScore[]
  propertyApps    PropertyApplication[]
  auditLogs       AuditLog[]
}

model IdentityCredential {
  id              String   @id @default(cuid())
  profileId       String
  credentialType  String   // passport, national_id, visa, residence_permit, biometric, banking, employer, university, government
  credentialValue String   // encrypted/reference
  trustLevel      Int      // maps to Trust Ladder level
  issuingCountry  String?
  issuingAuthority String?
  validFrom       DateTime?
  validTo         DateTime?
  verificationStatus String @default("pending") // pending, verified, failed, expired
  verifiedAt      DateTime?
  evidenceHash    String?  // hash of supporting evidence
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profile         IdentityProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model IdentityEvidence {
  id              String   @id @default(cuid())
  profileId       String
  evidenceType    String   // document, biometric, behavioral, institutional, government
  evidenceData    String   // JSON - encrypted evidence metadata
  confidence      Float    @default(0) // 0-1 confidence score
  source          String?
  verifiedBy      String?
  verifiedAt      DateTime?
  expiresAt       DateTime?
  createdAt       DateTime @default(now())

  profile         IdentityProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model VerificationRecord {
  id              String   @id @default(cuid())
  profileId       String
  verificationType String  // document, biometric_face, liveness, open_banking, income, employer, university, government
  status          String   @default("pending") // pending, in_progress, passed, failed, expired
  provider        String?  // verification provider
  result          String?  // JSON result data
  confidence      Float    @default(0)
  attemptCount    Int      @default(1)
  completedAt     DateTime?
  createdAt       DateTime @default(now())

  profile         IdentityProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// ============================================
// COMPLIANCE DOMAIN
// ============================================

model ComplianceCheck {
  id              String   @id @default(cuid())
  profileId       String
  checkType       String   // aml, kyc, cdd, edd, sanctions, pep, adverse_media, right_to_rent
  status          String   @default("pending") // pending, in_progress, passed, failed, escalated
  riskRating      String   @default("low") // low, medium, high, critical
  checkProvider   String?
  results         String?  // JSON - detailed results
  evidenceRef     String?  // reference to supporting evidence
  reviewedBy      String?
  reviewedAt      DateTime?
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profile         IdentityProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// ============================================
// RISK DOMAIN
// ============================================

model RiskScore {
  id              String   @id @default(cuid())
  profileId       String
  overallScore    Float    @default(0) // 0-100 (100 = lowest risk)
  riskCategory    String   @default("medium") // low, medium, high, critical
  fraudProbability Float   @default(0) // 0-1
  identityRisk    Float    @default(0)
  financialRisk   Float    @default(0)
  behavioralRisk  Float    @default(0)
  complianceRisk  Float    @default(0)
  riskFactors     String?  // JSON - detailed risk factor breakdown
  modelVersion    String?
  explainability  String?  // JSON - explainability data for the score
  createdAt       DateTime @default(now())

  profile         IdentityProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model FraudAlert {
  id              String   @id @default(cuid())
  alertType       String   // identity_fraud, document_fraud, synthetic_identity, money_laundering, suspicious_behavior
  severity        String   @default("medium") // low, medium, high, critical
  status          String   @default("open") // open, investigating, confirmed, false_positive, resolved
  description     String
  evidenceRef     String?  // JSON
  relatedProfileId String?
  assignedTo      String?
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// PROPERTY DOMAIN
// ============================================

model Property {
  id              String   @id @default(cuid())
  address         String
  city            String
  postcode        String
  country         String   @default("GB")
  propertyType    String   // residential, commercial, hmo
  bedrooms        Int?
  complianceStatus String  @default("pending") // pending, compliant, non_compliant, under_review
  lastInspection  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  applications    PropertyApplication[]
}

model PropertyApplication {
  id              String   @id @default(cuid())
  propertyId      String
  profileId       String
  applicationType String   // tenancy, purchase, rental
  status          String   @default("submitted") // submitted, under_review, approved, rejected, withdrawn
  complianceClear Boolean  @default(false)
  riskClear       Boolean  @default(false)
  rightToRent     String   @default("pending") // pending, verified, failed, expired
  guarantorReplaced Boolean @default(false)
  depositAmount   Float?
  monthlyAmount   Float?
  startDate       DateTime?
  endDate         DateTime?
  submittedAt     DateTime @default(now())
  decidedAt       DateTime?

  property        Property @relation(fields: [propertyId], references: [id])
  profile         IdentityProfile @relation(fields: [profileId], references: [id])
}

// ============================================
// PARTNER DOMAIN
// ============================================

model Partner {
  id              String   @id @default(cuid())
  name            String
  partnerType     String   // bank, insurer, mortgage_provider, remittance, employer, university
  status          String   @default("active") // active, suspended, terminated
  apiEndpoint     String?
  integrationType String?  // api, webhook, batch, manual
  trustRating     Float    @default(0) // 0-100
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  referrals       PartnerReferral[]
  users           User[]
}

model PartnerReferral {
  id              String   @id @default(cuid())
  partnerId       String
  profileId       String?
  referralType    String   // banking, insurance, mortgage, remittance
  status          String   @default("pending") // pending, sent, accepted, completed, failed
  referralData    String?  // JSON
  createdAt       DateTime @default(now())

  partner         Partner @relation(fields: [partnerId], references: [id])
}

// ============================================
// AUDIT & GOVERNANCE
// ============================================

model AuditLog {
  id              String   @id @default(cuid())
  profileId       String?
  userId          String?
  action          String
  performedBy     String?
  resource        String
  resourceId      String?
  details         String?  // JSON
  ipAddress       String?
  timestamp       DateTime @default(now())

  profile         IdentityProfile? @relation(fields: [profileId], references: [id])
  user            User? @relation(fields: [userId], references: [id])
}

model ConsentRecord {
  id              String   @id @default(cuid())
  profileId       String?
  userId          String?
  consentType     String   // data_processing, marketing, third_party_sharing, automated_decisions
  granted         Boolean
  purpose         String?
  legalBasis      String?  // consent, legitimate_interest, contract, legal_obligation
  withdrawnAt     DateTime?
  expiresAt       DateTime?
  createdAt       DateTime @default(now())

  user            User? @relation(fields: [userId], references: [id])
}

// ============================================
// USER & AUTH DOMAIN
// ============================================

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String
  passwordHash    String
  role            String   @default("viewer") // platform_admin, compliance_officer, property_manager, identity_verifier, risk_analyst, partner_user, tenant
  avatar          String?  // initials or URL
  department      String?
  jobTitle        String?
  phone           String?
  mfaEnabled      Boolean  @default(false)
  mfaSecret       String?
  lastLoginAt     DateTime?
  lastLoginIp     String?
  loginAttempts   Int      @default(0)
  lockedUntil     DateTime?
  partnerId       String?  // Links partner_user to their Partner for data isolation
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sessions        UserSession[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  consentRecords  ConsentRecord[]
  profiles        IdentityProfile[]
  partner         Partner? @relation(fields: [partnerId], references: [id])
}

model UserSession {
  id              String   @id @default(cuid())
  userId          String
  token           String   @unique
  device          String?
  browser         String?
  ipAddress       String?
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id              String   @id @default(cuid())
  userId          String
  title           String
  message         String
  type            String   @default("info") // info, warning, error, success, compliance, risk
  category        String   @default("system") // system, compliance, risk, property, identity, partner
  read            Boolean  @default(false)
  actionUrl       String?
  createdAt       DateTime @default(now())
  readAt          DateTime?

  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// PLATFORM CONFIG
// ============================================

model PlatformConfig {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String
  description     String?
  updatedAt       DateTime @updatedAt
}

// ============================================
// PROCESS WORKFLOW DOMAIN
// ============================================

model OnboardingProcess {
  id              String   @id @default(cuid())
  profileId       String?
  applicantEmail  String
  applicantName   String
  nationality     String?
  currentStep     Int      @default(1) // 1-10 steps
  status          String   @default("draft") // draft, in_progress, pending_review, certified, rejected
  
  // Step 1: Account Registration
  registrationMethod String? // email, google, microsoft
  mfaEnforced     Boolean  @default(false)
  
  // Step 2: Identity Evidence
  passportUploaded Boolean @default(false)
  visaUploaded     Boolean @default(false)
  financialFilesUploaded Boolean @default(false)
  
  // Step 3: Biometric Verification
  selfieCaptured   Boolean @default(false)
  livenessScore    Float?
  faceMatchScore   Float?
  deepfakeScore    Float?
  biometricConfidence Float?
  
  // Step 4: Financial Behaviour
  financialMonthsAnalyzed Int?
  incomeStability  Float?
  spendingCoherence Float?
  professionMatch  Float?
  
  // Step 5: Cross-Jurisdictional
  sourceCountryDb  String? // e.g. NIN, Aadhaar
  sourceCountryVerified Boolean @default(false)
  homeOfficeVerified Boolean @default(false)
  professionalRegistryVerified Boolean @default(false)
  
  // Step 6: Triple Source Corroboration
  biometricScore   Float?
  behaviouralScore Float?
  jurisdictionalScore Float?
  overallConfidenceScore Float? // 0-100
  
  // Step 7: Confidence Gateway
  gatewayPassed    Boolean @default(false)
  gatewayResult    String? // auto_certified, manual_review
  
  // Step 8: Risk Assessment
  identityRisk     Float?
  amlRisk          Float?
  financialRisk    Float?
  tenancyRisk      Float?
  
  // Step 9: Credential Generation
  credentialIssued Boolean @default(false)
  credentialToken  String?
  
  // Step 10: Agent Review
  agentReviewed    Boolean @default(false)
  agentDecision    String? // approved, rejected, more_evidence_needed
  reviewedBy       String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AMLProcess {
  id              String   @id @default(cuid())
  profileId       String?
  transactionRef  String   @unique
  propertyRef     String?
  currentStep     Int      @default(1) // 1-7 steps
  status          String   @default("initialized") // initialized, identity_check, cdd, screening, edd, decision, sar, completed
  
  // Step 1: Transaction Initialization
  transactionType String? // property_application, real_estate_participant
  transactionAmount Float?
  
  // Step 2: Identity Verification Integration
  identityVerified Boolean @default(false)
  kycComplete      Boolean @default(false)
  
  // Step 3: Customer Due Diligence
  cddComplete      Boolean @default(false)
  riskClassification String? // low, medium, high, critical
  
  // Step 4: Watchlist Screening
  sanctionsCheck   String? // clear, match, potential_match
  pepCheck         String? // clear, match, potential_match
  adverseMediaCheck String? // clear, match, potential_match
  screeningProvider String?
  screeningDate    DateTime?
  
  // Step 5: Source of Funds & EDD
  eddRequired      Boolean @default(false)
  sofVerified      Boolean @default(false)
  sourceOfFunds    String?
  eddComplete      Boolean @default(false)
  
  // Step 6: Compliance Decision
  decisionResult   String? // cleared, flagged, locked_down
  amlRiskScore     Float?
  decidedBy        String?
  decidedAt        DateTime?
  
  // Step 7: SAR Generation
  sarGenerated     Boolean @default(false)
  sarReference     String?
  sarFiledAt       DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RightToRentProcess {
  id              String   @id @default(cuid())
  profileId       String?
  agentId         String?
  propertyId      String?
  currentStep     Int      @default(1) // 1-7 steps
  status          String   @default("initiated") // initiated, visa_ingestion, home_office, status_check, risk_assessment, certification, monitoring, completed
  
  // Step 1: Initiate Check
  initiatedBy     String?
  checkReason     String?
  
  // Step 2: Visa Ingestion & OCR
  visaType        String? // tier2, student, eu_settlement, resident_permit, etc.
  documentAuthentic Boolean @default(false)
  tamperingCheck  Boolean @default(false)
  ocrConfidence   Float?
  
  // Step 3: Home Office Validation
  visaGrantValid  Boolean @default(false)
  ukResidenceData Boolean @default(false)
  immigrationPermissions Boolean @default(false)
  homeOfficeCheckDate DateTime?
  
  // Step 4: Status & Visa Verification
  permanentRight  Boolean @default(false)
  timeLimitedStatus Boolean @default(false)
  expiryDate      DateTime?
  restrictions    String? // JSON
  
  // Step 5: Risk & Compliance Assessment
  complianceResult String? // pass, fail, review
  rulesEngineResult String? // JSON
  statutoryGuidelineMet Boolean @default(false)
  
  // Step 6: Evidence Generation & Certification
  certificateIssued Boolean @default(false)
  certificateToken String?
  evidenceTrailRef String?
  issuedAt        DateTime?
  expiresAt       DateTime?
  
  // Step 7: Continuous Expiry Monitoring
  monitoringActive Boolean @default(false)
  daysToExpiry    Int?
  lastAlertSent   DateTime?
  alertStatus     String? // none, warning, critical, expired
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
