# ─── PropComply AI — Environment Variables ───────────────────────────────
# Copy to .env for local dev, or set these in the Vercel dashboard for prod.

# PostgreSQL (Neon). Use the POOLED connection string for DATABASE_URL and the
# DIRECT (non-pooled) string for DIRECT_URL. Both must end with ?sslmode=require.
# Neon dashboard → Connection Details → "Pooled connection" / "Direct connection".
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-west-2.aws.neon.tech/propcomply?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.eu-west-2.aws.neon.tech/propcomply?sslmode=require"

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-32-char-random-secret"
# In production set this to your deployed URL, e.g. https://propcomply.vercel.app
NEXTAUTH_URL="http://localhost:3000"
